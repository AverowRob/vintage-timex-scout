# eBay Browse API credentials (client-credentials / app token flow).
# Get these from https://developer.ebay.com → "Application Keys" (production keyset).
# The app authenticates as itself; there is no per-user login (see README §8).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# "production" or "sandbox". Sandbox has almost no real inventory; use production
# for a meaningful pull. Default: production.
EBAY_ENV=production

# Etsy Open API v3 — second marketplace (E1 Next). Keystring auth for public
# listing search; request keys at https://www.etsy.com/developers. When present,
# Re-pull also pulls Etsy and the Etsy source dot turns yellow (wired) / green (live).
ETSY_KEYSTRING=
ETSY_SHARED_SECRET=

# LLM interest judge. Default provider is Google Gemini (Flash tier) — paste the
# key from your Averow project here and the judge uses it automatically. Optional:
# GEMINI_MODEL overrides the model (default: gemini-2.5-flash).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Alternative provider: Anthropic Claude (Haiku). If GEMINI_API_KEY is unset but
# this is set, the judge uses Claude instead. With neither, it falls back to the
# deterministic keyword judge (no LLM) so the app still runs.
ANTHROPIC_API_KEY=
